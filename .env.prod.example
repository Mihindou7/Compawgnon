# ─────────────────────────────────────────────────────────────────────────────
# Compawgnon — Variables d'environnement PRODUCTION
# Copier ce fichier en .env à la racine du serveur (/opt/compawgnon/.env)
# NE JAMAIS committer le .env rempli dans git
# ─────────────────────────────────────────────────────────────────────────────

# ── Domaine ──────────────────────────────────────────────────────────────────
DOMAIN=compawgnon.fr
CADDY_ADMIN_EMAIL=admin@compawgnon.fr

# ── Symfony ──────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
APP_SECRET=CHANGE_ME_32_char_hex_string

# ── Base de données MySQL ─────────────────────────────────────────────────────
MYSQL_DB=compawgnon
MYSQL_USER=compawgnon
# Générer avec : openssl rand -base64 24
MYSQL_PASSWORD=CHANGE_ME_strong_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Phrase de passe pour les clés RSA JWT (générées par setup-server.sh)
# Générer avec : openssl rand -base64 32
JWT_PASSPHRASE=CHANGE_ME_jwt_passphrase

# ── Mercure ───────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
CADDY_MERCURE_JWT_SECRET=CHANGE_ME_mercure_secret

# ── Mail — Brevo SMTP ─────────────────────────────────────────────────────────
# 1. Créer un compte sur https://app.brevo.com
# 2. Paramètres > Clés API SMTP > Générer une clé SMTP
# 3. Login SMTP = ton email Brevo, Password = la clé générée
MAILER_DSN=smtp://TON_EMAIL_BREVO:TA_CLE_SMTP_BREVO@smtp-relay.brevo.com:587
MAILER_FROM_ADDRESS=noreply@compawgnon.fr
MAILER_FROM_NAME=Compawgnon

# ── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Ajouter https://compawgnon.fr/api/auth/google/callback aux URIs autorisés
GOOGLE_CLIENT_ID=TON_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TON_CLIENT_SECRET
